@model IEnumerable<MyWebPage.Models.Project>
@{
    ViewData["Title"] = "Projeler";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Projeler</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Proje Ekle</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Başlık</th>
            <th>Teknolojiler</th>
            <th>Canlı Link</th>
            <th style="width:150px">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Technologies</td>
                <td>@item.LiveLink</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?');">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
