@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Girişi - Portfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            background-image: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.15), transparent 60%);
        }
        .login-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 3rem;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
        }
        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #3b82f6;
            color: #fff;
            box-shadow: none;
        }
        .btn-custom {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border: none;
            color: #fff;
            font-weight: 600;
        }
        .btn-custom:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body>
    <div class="login-panel">
        <h3 class="text-center mb-4 fw-bold">Admin Girişi</h3>
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger py-2 text-center" style="font-size:0.9rem;">@ViewBag.ErrorMessage</div>
        }
        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input type="text" name="username" class="form-control" required />
            </div>
            <div class="mb-4">
                <label class="form-label">Şifre</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-custom w-100 py-2">Giriş Yap</button>
        </form>
        <div class="text-center mt-3">
            <a href="/" class="text-muted text-decoration-none" style="font-size: 0.85rem;">&larr; Siteye Dön</a>
        </div>
    </div>
</body>
</html>
