@model IEnumerable<MyWebPage.Models.Experience>
@{
    ViewData["Title"] = "İş Deneyimleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>İş Deneyimleri</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Yeni Ekle</a>
</div>

<div class="card bg-dark text-light">
    <div class="card-body">
        <table class="table table-dark table-hover table-striped">
            <thead>
                <tr>
                    <th>Pozisyon</th>
                    <th>Şirket</th>
                    <th>Tarih</th>
                    <th>Devam Ediyor Mu?</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td>@item.Position</td>
                        <td>@item.Company</td>
                        <td>@item.StartDate - @(item.IsCurrent ? "Devam Ediyor" : item.EndDate)</td>
                        <td>
                            @if(item.IsCurrent)
                            {
                                <span class="badge bg-success">Evet</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Hayır</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bu deneyimi silmek istediğinize emin misiniz?');">Sil</a>
                        </td>
                    </tr>
                }
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center">Henüz iş deneyimi eklenmemiş.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
